magisterium/_metadata/phase-state.json
# Binary PDFs: not versioned (source URL is in the sibling .meta.yaml so they
# can be re-fetched via `just resume` ou via la phase de scraping idempotente
# correspondante). Prevents >100 MB files breaking git remotes and keeps the
# repo text-focused.
magisterium/**/*.pdf
livres/**/*.pdf
