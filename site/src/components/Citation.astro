---
import { getDocumentBySlug } from '../data/loadDocuments.js';

interface Props {
  lang: 'la' | 'it' | 'en' | 'de' | 'es' | 'pt';
  source?: string;
  translation: string;
  /**
   * Slug du document dans le corpus. Si fourni, la source devient un lien
   * cliquable vers /documents/<slug>/.
   */
  doc_slug?: string;
}

const { lang, source, translation, doc_slug } = Astro.props;

const exists = doc_slug ? Boolean(getDocumentBySlug(doc_slug)) : false;
---

<figure class="citation" lang={lang}>
  <blockquote class="citation__original prose-latin" lang={lang}>
    <slot />
  </blockquote>

  <div class="citation__translation" lang="fr">
    {translation}
  </div>

  {source && (
    <figcaption class="citation__source">
      {doc_slug && exists ? (
        <a href={`/documents/${doc_slug}/`} class="citation__source-link">
          <cite>{source}</cite>
          <span class="citation__source-arrow" aria-hidden="true">→</span>
        </a>
      ) : (
        <cite>{source}</cite>
      )}
    </figcaption>
  )}
</figure>

<style>
  .citation {
    margin: var(--space-l) 0;
    max-width: var(--measure);
  }

  .citation__original {
    margin: 0;
    padding: var(--space-s) var(--space-m);
    background-color: var(--quote-bg);
    border-left: 3px solid var(--gold);
    font-family: var(--font-serif);
    font-style: italic;
    font-variant-numeric: oldstyle-nums;
    color: var(--ink-soft);
    line-height: var(--line-height-prose);
  }

  .citation__translation {
    margin-top: 0;
    padding: var(--space-s) var(--space-m);
    border-left: 3px solid var(--gold);
    background-color: transparent;
    color: var(--ink);
    font-style: normal;
    font-family: var(--font-serif);
    line-height: var(--line-height-prose);
  }

  .citation__source {
    margin-top: var(--space-2xs);
    padding-left: calc(var(--space-m) + 3px);
    color: var(--muted);
    font-size: 0.875em;
    font-style: italic;
  }

  .citation__source cite {
    font-style: italic;
  }

  .citation__source-link {
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms ease;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
  }

  .citation__source-link:hover,
  .citation__source-link:focus-visible {
    color: var(--rubric);
  }

  .citation__source-arrow {
    font-size: 0.85em;
    opacity: 0.6;
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .citation__source-link:hover .citation__source-arrow,
  .citation__source-link:focus-visible .citation__source-arrow {
    opacity: 1;
    transform: translateX(2px);
  }
</style>
