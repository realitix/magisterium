---
/**
 * Grille de documents cités — affichée en pied de fiche Q/R.
 * Cartes enrichies : titre, auteur, date, type, badge de période.
 * Documents regroupés par période (pré-V2, V2, post-V2) pour la lisibilité.
 */
import { getDocumentBySlug } from '../data/loadDocuments.js';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;

type Entry = {
  slug: string;
  titre: string | null;
  auteur: string | null;
  date: string | null;
  type: string | null;
  periode: string | null;
  found: boolean;
};

const entries: Entry[] = slugs.map((s) => {
  const doc = getDocumentBySlug(s);
  return {
    slug: s,
    titre: doc?.titre_fr ?? doc?.incipit ?? null,
    auteur: doc?.auteur ?? null,
    date: doc?.date ?? null,
    type: doc?.type ?? null,
    periode: doc?.periode ?? null,
    found: Boolean(doc),
  };
});

function formatDate(raw: string | null): string | null {
  if (!raw) return null;
  const d = new Date(raw);
  if (Number.isNaN(d.getTime())) {
    // Essayer de récupérer l'année au moins (pour les dates historiques anciennes)
    const m = raw.match(/^(\d{3,4})/);
    return m ? m[1] : raw;
  }
  return d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
}

function periodeLabel(p: string | null): string {
  switch (p) {
    case 'pre-vatican-ii':
      return 'Pré-Vatican II';
    case 'vatican-ii':
      return 'Vatican II';
    case 'post-vatican-ii':
      return 'Post-Vatican II';
    case 'fsspx':
      return 'FSSPX';
    default:
      return 'Autres';
  }
}

const ORDER = ['pre-vatican-ii', 'vatican-ii', 'post-vatican-ii', 'fsspx'];
const groups = new Map<string, Entry[]>();
for (const e of entries) {
  const key = e.periode ?? 'autres';
  const arr = groups.get(key) ?? [];
  arr.push(e);
  groups.set(key, arr);
}
const orderedGroups = [...ORDER, ...[...groups.keys()].filter((k) => !ORDER.includes(k))]
  .filter((k) => groups.has(k))
  .map((k) => ({ key: k, items: groups.get(k)! }));
---

{
  entries.length > 0 && (
    <section class="docs-grid" aria-labelledby="docs-grid-title">
      <header class="docs-grid__header">
        <p class="docs-grid__eyebrow">Renvois</p>
        <h2 id="docs-grid-title" class="docs-grid__title">
          Documents cités
        </h2>
        <p class="docs-grid__lede">
          Les sources primaires invoquées dans cette fiche, en langue originale.
          Cliquez pour lire le texte intégral.
        </p>
      </header>

      <div class="docs-grid__groups">
        {orderedGroups.map((g) => (
          <section class="docs-grid__group">
            <h3 class={`docs-grid__group-title docs-grid__group-title--${g.key}`}>
              {periodeLabel(g.key)}
              <small class="docs-grid__group-count">{g.items.length}</small>
            </h3>
            <ul class="docs-grid__list" role="list">
              {g.items.map((e) => (
                <li class={`doc-card doc-card--${e.periode ?? 'autres'} ${e.found ? '' : 'doc-card--missing'}`}>
                  {e.found ? (
                    <a class="doc-card__link" href={`/documents/${e.slug}/`}>
                      <h4 class="doc-card__title">{e.titre ?? e.slug}</h4>
                      <p class="doc-card__meta">
                        {e.auteur && <span>{e.auteur}</span>}
                        {e.auteur && (e.date || e.type) && <span aria-hidden="true"> · </span>}
                        {e.date && <span>{formatDate(e.date)}</span>}
                        {e.type && (
                          <>
                            {e.date && <span aria-hidden="true"> · </span>}
                            <span class="doc-card__type">{e.type}</span>
                          </>
                        )}
                      </p>
                    </a>
                  ) : (
                    <div class="doc-card__link">
                      <h4 class="doc-card__title">{e.slug}</h4>
                      <p class="doc-card__meta">
                        <em>Document introuvable dans le corpus local</em>
                      </p>
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </section>
  )
}

<style>
  .docs-grid {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--rule);
  }

  .docs-grid__header {
    max-width: 60ch;
    margin: 0 auto var(--space-xl);
    text-align: center;
  }

  .docs-grid__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.72rem;
    color: var(--muted);
    margin: 0 0 var(--space-xs);
  }

  .docs-grid__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.2rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-s);
  }

  .docs-grid__lede {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    margin: 0;
    line-height: var(--line-height-prose);
  }

  .docs-grid__groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .docs-grid__group {
    display: block;
  }

  .docs-grid__group-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink-soft);
    margin: 0 0 var(--space-m);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .docs-grid__group-title--pre-vatican-ii {
    border-bottom-color: var(--gold);
  }

  .docs-grid__group-title--vatican-ii {
    border-bottom-color: var(--muted);
  }

  .docs-grid__group-title--post-vatican-ii {
    border-bottom-color: var(--rubric);
  }

  .docs-grid__group-count {
    font-family: var(--font-serif);
    font-variant-numeric: oldstyle-nums;
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0;
    text-transform: none;
  }

  .docs-grid__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-m);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .doc-card {
    background-color: var(--paper-dim);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--muted);
    transition: border-color 150ms ease, background-color 150ms ease, transform 150ms ease;
  }

  .doc-card--pre-vatican-ii {
    border-left-color: var(--gold);
  }

  .doc-card--vatican-ii {
    border-left-color: var(--muted);
  }

  .doc-card--post-vatican-ii {
    border-left-color: var(--rubric);
  }

  .doc-card:hover,
  .doc-card:focus-within {
    border-color: color-mix(in srgb, var(--rubric) 35%, var(--rule));
    background-color: var(--paper);
    transform: translateY(-1px);
  }

  .doc-card--missing {
    opacity: 0.6;
  }

  .doc-card--missing:hover {
    transform: none;
  }

  .doc-card__link {
    display: block;
    padding: var(--space-m);
    color: inherit;
    text-decoration: none;
  }

  .doc-card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 var(--space-2xs);
  }

  a.doc-card__link:hover .doc-card__title,
  a.doc-card__link:focus-visible .doc-card__title {
    color: var(--rubric);
  }

  .doc-card__meta {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.4;
  }

  .doc-card__type {
    font-style: italic;
  }
</style>
