---
/**
 * Document.astro — layout d'une fiche document individuelle.
 * Consomme les métadonnées enrichies (Document) et le contenu markdown
 * déjà rendu en HTML par la page appelante.
 */
import Base from './Base.astro';
import LangFlag from '../components/LangFlag.astro';
import Tampon from '../components/Tampon.astro';
import { getOuvrageParts } from '../data/loadDocuments.ts';
import { getClericIndex, getClericOfDocument, tamponOf } from '../data/loadClerge.ts';
import type { Document, DocumentMeta, Langue, TraductionKind } from '../data/types.ts';

interface Props {
  doc: Document;
  meta: DocumentMeta;
  /** Langue effectivement rendue (celle du .md chargé). */
  lang: Langue;
  /** Provenance de la traduction servie. */
  kind: TraductionKind;
  /** HTML déjà rendu depuis le markdown. */
  renderedHtml: string;
}

const { doc, meta, lang, kind, renderedHtml } = Astro.props;

/**
 * Titre principal : depend de la langue de la page.
 *  - page FR → `titre_fr` (titre francais naturel), subtitle = incipit.
 *  - toute autre langue (la/it/en/es/…) → `incipit` (le nom canonique du
 *    document dans la tradition catholique, langue-agnostique), subtitle =
 *    `titre_fr` pour que la recherche FR retombe aussi sur la page.
 *
 * Cote Pagefind : h1 = weight 10 (match fort), subtitle = weight 6.
 * Une recherche « fratelli » classe en premier les pages non-FR (match h1) ;
 * une recherche « fraternité » classe en premier la page FR (match h1).
 */
const incipit = (doc.incipit ?? meta.incipit ?? null) as string | null;
const titreFr = (doc.titre_fr ?? meta.titre_fr ?? null) as string | null;
const ouvragePartTitle = doc.ouvrage?.partie_titre ?? null;

let title: string;
let subtitle: string | null;
if (ouvragePartTitle !== null) {
  // Pour une partie d'ouvrage, le `partie_titre` est plus informatif que le
  // titre_fr générique (souvent partagé entre toutes les parties, ex. CEC).
  // On l'utilise en H1 ; l'incipit ou titre_fr descend en sous-titre.
  title = ouvragePartTitle;
  if (lang === 'fr' && titreFr !== null && titreFr !== title) {
    subtitle = titreFr;
  } else if (incipit !== null && incipit !== title) {
    subtitle = incipit;
  } else {
    subtitle = null;
  }
} else if (lang === 'fr' && titreFr !== null) {
  title = titreFr;
  subtitle = (incipit !== null && incipit !== titreFr) ? incipit : null;
} else {
  title = incipit ?? titreFr ?? (doc.slug as string);
  subtitle = (titreFr !== null && titreFr !== title) ? titreFr : null;
}
// On peut aussi vouloir exposer le titre original (latin/grec) quand on est
// sur une page non-fr et que le titre_original differe du titre courant.
if (subtitle === null && meta.titre_original !== undefined && meta.titre_original !== null && meta.titre_original !== title) {
  subtitle = meta.titre_original;
}

/** Libellés humains des périodes. */
const PERIODE_LABELS: Readonly<Record<string, string>> = {
  'pre-vatican-ii': 'Pré-Vatican II',
  'vatican-ii': 'Vatican II',
  'post-vatican-ii': 'Post-Vatican II',
  fsspx: 'FSSPX',
};

/** Couleur du badge période : rubrique pour V2+, or pour pré-V2, muted ailleurs. */
function periodeBadgeClass(p: string): string {
  if (p === 'vatican-ii' || p === 'post-vatican-ii') return 'badge--rubric';
  if (p === 'pre-vatican-ii') return 'badge--gold';
  return 'badge--muted';
}

/** Libellés humains des langues. */
const LANG_LABELS: Readonly<Record<string, string>> = {
  la: 'latin',
  fr: 'français',
  it: 'italien',
  en: 'anglais',
  de: 'allemand',
  es: 'espagnol',
  pt: 'portugais',
  el: 'grec',
};

/** Mois français pour le formatage des dates. */
const FRENCH_MONTHS: readonly string[] = [
  'janvier', 'février', 'mars', 'avril', 'mai', 'juin',
  'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre',
];

/**
 * Formatte une date ISO ("YYYY-MM-DD" ou "YYYY-MM" ou "YYYY") en français.
 * Exemples : "1598-07-15" -> "15 juillet 1598".
 */
function formatFrenchDate(iso: string | null | undefined): string | null {
  if (iso === null || iso === undefined || iso.trim().length === 0) return null;
  const m = /^(\d{1,4})(?:-(\d{2}))?(?:-(\d{2}))?/.exec(iso);
  if (m === null) return iso;
  const year = Number.parseInt(m[1], 10);
  const monthIdx = m[2] !== undefined ? Number.parseInt(m[2], 10) - 1 : null;
  const day = m[3] !== undefined ? Number.parseInt(m[3], 10) : null;
  if (day !== null && monthIdx !== null && monthIdx >= 0 && monthIdx < 12) {
    return `${day} ${FRENCH_MONTHS[monthIdx]} ${year}`;
  }
  if (monthIdx !== null && monthIdx >= 0 && monthIdx < 12) {
    return `${FRENCH_MONTHS[monthIdx]} ${year}`;
  }
  return String(year);
}

const dateFormatted = formatFrenchDate(doc.date);
const periodeLabel = PERIODE_LABELS[doc.periode] ?? doc.periode;
const periodeClass = periodeBadgeClass(doc.periode);

/** Navigation entre parties d'un ouvrage multi-fichiers. */
const ouvrage = doc.ouvrage;
const ouvrageParts = ouvrage !== null ? getOuvrageParts(doc.slug) : [];
/** Retourne la partie à l'offset donné (prev = -1, next = +1) ou null. */
function findPartAtOffset(offset: number): Document | null {
  if (ouvrage === null) return null;
  const targetIndex = ouvrage.partie_index + offset;
  return ouvrageParts.find((p) => p.ouvrage?.partie_index === targetIndex) ?? null;
}
const prevPart = findPartAtOffset(-1);
const nextPart = findPartAtOffset(1);
/**
 * URL pour une partie sœur dans la langue courante si disponible, sinon
 * repli sur la langue originale de cette partie (évite les 404 quand
 * telle partie n'existe pas dans la langue qu'on lit).
 */
function partHref(part: Document): string {
  const hasCurrentLang = part.traductions.some((t) => t.lang === lang);
  const targetLang = hasCurrentLang ? lang : part.langue_originale;
  return `/documents/${part.slug}/${targetLang}/`;
}

/** Meta préfèrera la source dans la langue rendue ; sinon la première. */
const sources = Array.isArray(meta.sources) ? meta.sources : [];
const primarySource = sources.find((s) => s?.langue === lang) ?? sources[0];

/** SHA-256 : chaîne brute ou mapping par langue. */
let shaDisplay: string | null = null;
if (typeof meta.sha256 === 'string' && meta.sha256.length > 0) {
  shaDisplay = meta.sha256;
} else if (typeof meta.sha256 === 'object' && meta.sha256 !== null) {
  const map = meta.sha256 as Record<string, string>;
  shaDisplay = map[lang] ?? Object.values(map)[0] ?? null;
} else if (typeof doc.sha256 === 'string' && doc.sha256.length > 0) {
  shaDisplay = doc.sha256;
}

/** Traductions dispos avec leur provenance, triées : originale puis officielles puis IA. */
const KIND_ORDER: Record<TraductionKind, number> = { originale: 0, officielle: 1, ia: 2 };
const traductionsList = [...doc.traductions].sort((a, b) => {
  const byKind = KIND_ORDER[a.kind] - KIND_ORDER[b.kind];
  if (byKind !== 0) return byKind;
  return a.lang.localeCompare(b.lang);
});

/** Libellé de provenance pour une chip de langue. */
const KIND_LABELS: Record<TraductionKind, string> = {
  originale: 'originale',
  officielle: 'trad. officielle',
  ia: 'trad. IA',
};

const isAi = kind === 'ia';
const iaModel = isAi ? (meta.traductions?.[lang]?.model ?? 'modèle IA') : null;
const iaSourceLang = isAi ? (meta.traductions?.[lang]?.translated_from ?? doc.langue_originale) : null;

const proseClass = lang === 'fr' ? 'prose' : 'prose prose-latin';

const pageDescription: string =
  meta.titre_original !== undefined && meta.titre_original !== null
    ? `${title} — ${meta.titre_original}`
    : title;

// Pont prosopographique : auteur du document → fiche clerc, tampon de rite.
const authorClericSlug = getClericOfDocument(doc.slug);
const authorClericIndex = authorClericSlug !== null ? getClericIndex(authorClericSlug) : null;
const authorTampon = authorClericSlug !== null ? tamponOf(authorClericSlug) : null;
// On affiche le tampon de rite quand il éclaire la portée canonique : pour
// les documents V2 / post-V2, le rite de consécration de l'auteur (1968+)
// est précisément la question doctrinale en jeu.
const showAuthorTampon =
  authorClericSlug !== null &&
  authorTampon !== null &&
  (doc.periode === 'post-vatican-ii' || doc.periode === 'vatican-ii');
---

<Base title={title} description={pageDescription} htmlLang={lang}>
  <main class="doc" id="main" data-pagefind-body data-pagefind-filter={`lang:${lang}`}>
    <nav class="doc__back" aria-label="Navigation">
      <a href="/documents/">← Retour à l'index</a>
    </nav>

    {ouvrage !== null && (
      <>
        {/*
          Meta Pagefind pour permettre au JS de recherche (SearchBar.astro)
          de regrouper les hits par ouvrage. Ces spans n'ont pas de contenu
          visible — Pagefind lit l'attribut `data-pagefind-meta="key:value"`.
        */}
        <span hidden data-pagefind-meta={`ouvrage:${ouvrage.slug}`}></span>
        <span hidden data-pagefind-meta={`ouvrage_titre:${ouvrage.titre}`}></span>
        <span hidden data-pagefind-meta={`partie_index:${ouvrage.partie_index}`}></span>
        <span hidden data-pagefind-meta={`partie_titre:${ouvrage.partie_titre}`}></span>
        <span hidden data-pagefind-meta={`total_parties:${ouvrage.total_parties}`}></span>

        <nav class="doc__ouvrage-crumb" aria-label="Ouvrage parent">
          <span class="doc__ouvrage-crumb-label">Dans l'ouvrage</span>
          <span class="doc__ouvrage-crumb-titre">{ouvrage.titre}</span>
          <span class="doc__ouvrage-crumb-badge">Partie {ouvrage.partie_index} / {ouvrage.total_parties}</span>
        </nav>
      </>
    )}

    <header class="doc__header">
      <p class="doc__eyebrow">
        {doc.auteur !== null && <span>{doc.auteur}</span>}
        {doc.auteur !== null && <span class="doc__sep">·</span>}
        <span>{doc.type}</span>
        {dateFormatted !== null && <span class="doc__sep">·</span>}
        {dateFormatted !== null && <span>{dateFormatted}</span>}
      </p>

      <h1 class="doc__title" data-pagefind-meta="title" data-pagefind-weight="10.0">{title}</h1>

      {subtitle !== null && (
        <p class="doc__subtitle" data-pagefind-weight="6.0">{subtitle}</p>
      )}

      <div class="doc__badges">
        <span class={`badge ${periodeClass}`}>{periodeLabel}</span>
        {meta.autorite_magisterielle !== undefined && meta.autorite_magisterielle !== null && (
          <span class="badge badge--muted">{meta.autorite_magisterielle}</span>
        )}
      </div>

      {doc.themes_doctrinaux.length > 0 && (
        <ul class="doc__themes" role="list" aria-label="Thèmes doctrinaux">
          {doc.themes_doctrinaux.map((themeSlug) => (
            <li>
              <a href={`/themes/${themeSlug}/`} class="doc__theme-link">{themeSlug.replace(/-/g, ' ')}</a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <section class="doc__lang-bar" aria-label="Changer de langue">
      <div class="doc__lang-bar-label">
        {traductionsList.length > 1 ? 'Versions disponibles' : 'Version unique'}
      </div>
      <ul class="doc__lang-list" role="list">
        {traductionsList.map((t) => {
          const isActive = t.lang === lang;
          const href = `/documents/${doc.slug}/${t.lang}/`;
          const langLabel = LANG_LABELS[t.lang] ?? t.lang;
          const kindLabel = KIND_LABELS[t.kind];
          const chipClass = [
            'doc__lang-chip',
            `doc__lang-chip--${t.kind}`,
            isActive ? 'doc__lang-chip--active' : '',
          ].filter(Boolean).join(' ');
          return (
            <li>
              {isActive ? (
                <span class={chipClass} aria-current="page">
                  <LangFlag lang={t.lang} class="doc__lang-chip-flag" />
                  <span class="doc__lang-chip-body">
                    <span class="doc__lang-chip-lang">{langLabel}</span>
                    <span class="doc__lang-chip-kind">{kindLabel}</span>
                  </span>
                </span>
              ) : (
                <a href={href} class={chipClass} hreflang={t.lang}>
                  <LangFlag lang={t.lang} class="doc__lang-chip-flag" />
                  <span class="doc__lang-chip-body">
                    <span class="doc__lang-chip-lang">{langLabel}</span>
                    <span class="doc__lang-chip-kind">{kindLabel}</span>
                  </span>
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </section>

    {isAi && (
      <aside class="doc__ai-banner" role="note" aria-label="Avertissement traduction IA">
        <p class="doc__ai-banner-title">Traduction générée par intelligence artificielle</p>
        <p class="doc__ai-banner-body">
          Ce texte a été traduit automatiquement par {iaModel} depuis la version
          <strong>{LANG_LABELS[iaSourceLang ?? doc.langue_originale] ?? iaSourceLang}</strong>.
          Le texte faisant autorité est la
          <a href={`/documents/${doc.slug}/${doc.langue_originale}/`}>version originale</a>.
          Merci de la consulter pour tout usage doctrinal, théologique ou liturgique.
        </p>
      </aside>
    )}

    <article class={proseClass} lang={lang}>
      <Fragment set:html={renderedHtml} />
    </article>

    <aside class="doc__meta" aria-label="Métadonnées techniques du document">
      <h2 class="doc__meta-title">Métadonnées techniques</h2>
      <dl class="doc__meta-list">
        {authorClericSlug !== null && authorClericIndex !== null && (
          <Fragment>
            <dt>Auteur</dt>
            <dd class="doc__meta-author">
              <a class="doc__meta-author-link" href={`/clerge/${authorClericSlug}/`}>
                {authorClericIndex.nom}
              </a>
              {showAuthorTampon && (
                <span class="doc__meta-author-tampon" aria-label={`Tampon canonique : ${authorTampon}`}>
                  <Tampon variant={authorTampon!} />
                </span>
              )}
            </dd>
          </Fragment>
        )}

        {primarySource?.url !== undefined && (
          <Fragment>
            <dt>Source</dt>
            <dd>
              <a href={primarySource.url} rel="noreferrer noopener nofollow" target="_blank">
                {primarySource.site ?? primarySource.url}
              </a>
            </dd>
          </Fragment>
        )}

        {shaDisplay !== null && (
          <Fragment>
            <dt>SHA-256</dt>
            <dd><code class="doc__sha">{shaDisplay}</code></dd>
          </Fragment>
        )}

        <dt>Identifiant</dt>
        <dd><code>{doc.slug}</code></dd>
      </dl>
    </aside>

    {ouvrage !== null && (prevPart !== null || nextPart !== null) && (
      <nav class="doc__part-nav" aria-label="Navigation entre parties de l'ouvrage">
        <p class="doc__part-nav-label">
          {ouvrage.titre}
          <span aria-hidden="true"> · </span>
          <span>Partie {ouvrage.partie_index} / {ouvrage.total_parties}</span>
        </p>
        <div class="doc__part-nav-row">
          <div class="doc__part-nav-slot">
            {prevPart !== null && (
              <a href={partHref(prevPart)} class="doc__part-nav-link doc__part-nav-link--prev" rel="prev">
                <span class="doc__part-nav-arrow" aria-hidden="true">←</span>
                <span class="doc__part-nav-body">
                  <span class="doc__part-nav-index">Partie {prevPart.ouvrage!.partie_index}</span>
                  <span class="doc__part-nav-titre">{prevPart.ouvrage!.partie_titre}</span>
                </span>
              </a>
            )}
          </div>
          <div class="doc__part-nav-slot">
            {nextPart !== null && (
              <a href={partHref(nextPart)} class="doc__part-nav-link doc__part-nav-link--next" rel="next">
                <span class="doc__part-nav-body">
                  <span class="doc__part-nav-index">Partie {nextPart.ouvrage!.partie_index}</span>
                  <span class="doc__part-nav-titre">{nextPart.ouvrage!.partie_titre}</span>
                </span>
                <span class="doc__part-nav-arrow" aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </div>
      </nav>
    )}

    <nav class="doc__back doc__back--bottom" aria-label="Navigation">
      <a href="/documents/">← Retour à l'index</a>
    </nav>
  </main>
</Base>

<style>
  .doc {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--space-l) var(--space-m) var(--space-2xl);
  }

  .doc__back {
    font-family: var(--font-display);
    font-size: 0.9rem;
    margin-bottom: var(--space-l);
  }

  .doc__back--bottom {
    margin-top: var(--space-2xl);
    margin-bottom: 0;
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
  }

  .doc__header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
  }

  .doc__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: var(--space-s);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3em;
    align-items: baseline;
  }

  .doc__sep {
    color: var(--rule);
  }

  .doc__title {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-xs);
  }

  .doc__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin-bottom: var(--space-m);
  }

  .doc__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin-bottom: var(--space-m);
  }

  .badge {
    display: inline-block;
    padding: 0.2em 0.65em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid transparent;
    line-height: 1.4;
  }

  .badge--rubric {
    color: var(--paper);
    background-color: var(--rubric);
  }

  .badge--gold {
    color: var(--ink);
    background-color: color-mix(in srgb, var(--gold) 28%, transparent);
    border-color: color-mix(in srgb, var(--gold) 55%, transparent);
  }

  .badge--muted {
    color: var(--ink-soft);
    background-color: var(--paper-dim);
    border-color: var(--rule);
  }

  .doc__themes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .doc__themes li {
    margin: 0;
  }

  .doc__theme-link {
    display: inline-block;
    padding: 0.15em 0.6em;
    border: 1px solid var(--rule);
    border-radius: 3px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    text-decoration: none;
    background-color: var(--paper-dim);
  }

  .doc__theme-link:hover,
  .doc__theme-link:focus-visible {
    color: var(--rubric);
    border-color: var(--rubric);
  }

  .doc__meta {
    margin-top: var(--space-2xl);
    padding: var(--space-m);
    background-color: var(--paper-dim);
    border: 1px solid var(--rule);
    border-radius: 4px;
  }

  .doc__meta-title {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: var(--space-s);
  }

  .doc__meta-list {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2xs) var(--space-m);
    margin: 0;
    font-size: 0.92rem;
  }

  .doc__meta-list dt {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: var(--muted);
    align-self: baseline;
    padding-top: 0.25em;
  }

  .doc__meta-list dd {
    margin: 0;
    color: var(--ink-soft);
    word-break: break-word;
  }

  .doc__meta-author {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
  }
  .doc__meta-author-link {
    color: var(--rubric);
    font-weight: 600;
    text-decoration: none;
  }
  .doc__meta-author-link:hover,
  .doc__meta-author-link:focus-visible {
    text-decoration: underline;
  }
  /* Réduit le tampon à une « pastille » discrète dans la sidebar. */
  .doc__meta-author-tampon {
    display: inline-block;
    transform: scale(0.55);
    transform-origin: left center;
    margin: -0.8em -2.5em -0.8em 0;
  }

  .doc__lang-bar {
    margin: var(--space-l) 0 var(--space-m);
    padding: var(--space-s) var(--space-m);
    border: 1px solid var(--rule);
    border-radius: 4px;
    background-color: var(--paper-dim);
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .doc__lang-bar-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  .doc__lang-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .doc__lang-chip {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.45em;
    padding: 0.3em 0.75em;
    border-radius: 3px;
    border: 1px solid var(--rule);
    background-color: var(--paper);
    text-decoration: none;
    color: var(--ink-soft);
    font-family: var(--font-display);
    font-size: 0.88rem;
    line-height: 1.2;
    transition: border-color 120ms ease, color 120ms ease, transform 120ms ease;
  }

  .doc__lang-chip:hover,
  .doc__lang-chip:focus-visible {
    border-color: var(--rubric);
    color: var(--rubric);
    transform: translateY(-1px);
  }

  .doc__lang-chip-body {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }

  .doc__lang-chip-lang {
    font-weight: 600;
