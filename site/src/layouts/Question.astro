---
import type { MarkdownHeading } from 'astro';
import Base from './Base.astro';
import FourVoices from '../components/FourVoices.astro';
import ToC from '../components/ToC.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import DocumentsGrid from '../components/DocumentsGrid.astro';
import { getThemeBySlug } from '../data/loadThemes.js';

interface Voice {
  tagline: string;
  body: string;
  punchline?: string;
}

interface Props {
  title: string;
  question: string;
  slug: string;
  date?: string;
  summary?: string;
  tags?: string[];
  related_documents?: string[];
  related_themes?: string[];
  posture?: 'traditionnelle' | 'neutre' | 'pastorale';
  voices?: {
    conciliaire?: Voice;
    ecclesia_dei?: Voice;
    fsspx?: Voice;
    sedevacantiste?: Voice;
  };
  headings?: MarkdownHeading[];
}

const {
  title,
  question,
  date,
  summary,
  tags = [],
  related_documents = [],
  related_themes = [],
  posture = 'traditionnelle',
  voices,
  headings = [],
} = Astro.props;

const postureLabel: Record<string, string> = {
  traditionnelle: 'Posture traditionnelle',
  neutre: 'Posture neutre',
  pastorale: 'Posture pastorale',
};

const themeLinks = related_themes.map((s) => {
  const theme = getThemeBySlug(s);
  return {
    slug: s,
    label: theme?.label ?? null,
  };
});

// Format date in French if present
let dateDisplay: string | null = null;
if (date) {
  try {
    const d = new Date(date);
    if (!Number.isNaN(d.getTime())) {
      dateDisplay = d.toLocaleDateString('fr-FR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    } else {
      dateDisplay = date;
    }
  } catch {
    dateDisplay = date;
  }
}
---

<Base title={title} description={summary ?? question}>
  <ReadingProgress />

  <main class="q" id="main" data-pagefind-body>
    <header class="q__header">
      <p class="q__eyebrow">Question</p>
      <h1 class="q__title" data-pagefind-meta="title" data-pagefind-weight="10.0">{title}</h1>
      <p class="q__question" data-pagefind-weight="5.0">{question}</p>
      {summary && <p class="q__summary" data-pagefind-weight="3.0">{summary}</p>}

      <div class="q__meta">
        {dateDisplay && (
          <time class="q__date" datetime={date}>{dateDisplay}</time>
        )}
        <span class={`q__posture q__posture--${posture}`}>
          {postureLabel[posture] ?? posture}
        </span>
        {tags.length > 0 && (
          <ul class="q__tags" role="list">
            {tags.map((tag) => <li class="q__tag">{tag}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="q__layout">
      <article class="prose q__body">
        <slot />
        {voices && <FourVoices voices={voices} />}
      </article>

      <aside class="q__toc-side" aria-label="Sommaire">
        <ToC headings={headings} />
      </aside>
    </div>

    <DocumentsGrid slugs={related_documents} />

    {themeLinks.length > 0 && (
      <section class="q__themes" aria-labelledby="themes-assoc-title">
        <h2 id="themes-assoc-title" class="q__themes-title">Thèmes associés</h2>
        <ul class="q__themes-list" role="list">
          {themeLinks.map((t) => (
            <li class="q__theme-chip">
              {t.label ? (
                <a href={`/themes/${t.slug}/`}>{t.label}</a>
              ) : (
                <span class="q__aside-missing">{t.slug}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="q__footer">
      <p class="q__disclaimer">
        Cette fiche est une compilation magistérielle selon la posture
        apologétique traditionnelle assumée. Elle ne se substitue pas à
        l'enseignement vivant de l'Église.
      </p>
      <p class="q__back">
        <a href="/questions/">Toutes les questions</a>
      </p>
    </footer>
  </main>

  <BackToTop />
</Base>

<style>
  .q {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-m);
  }

  .q__header {
    max-width: var(--measure);
    margin: 0 auto var(--space-xl);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
  }

  .q__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: var(--space-s);
  }

  .q__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-m);
  }

  .q__question {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 1.5vw + 0.75rem, 1.75rem);
    line-height: 1.35;
    color: var(--ink-soft);
    margin-bottom: var(--space-m);
  }

  .q__summary {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: var(--line-height-prose);
    margin-bottom: var(--space-m);
  }

  .q__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs) var(--space-s);
    margin-top: var(--space-m);
    font-size: 0.875rem;
  }

  .q__date {
    color: var(--muted);
    font-variant-numeric: oldstyle-nums;
  }

  .q__posture {
    display: inline-block;
    padding: 0.15em 0.6em;
    border: 1px solid var(--rule);
    border-radius: 2px;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background-color: var(--paper-dim);
  }

  .q__posture--traditionnelle {
    border-color: color-mix(in srgb, var(--rubric) 35%, var(--rule));
    color: var(--rubric);
  }

  .q__posture--pastorale {
    border-color: color-mix(in srgb, var(--gold) 50%, var(--rule));
    color: var(--gold);
  }

  .q__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs) var(--space-2xs);
    padding: 0;
    margin: 0;
  }

  .q__tag {
    display: inline-block;
    padding: 0.1em 0.55em;
    font-size: 0.8rem;
    font-family: var(--font-serif);
    color: var(--muted);
    background-color: var(--paper-dim);
    border-radius: 2px;
  }

  .q__layout {
    display: grid;
    grid-template-columns: minmax(0, var(--measure)) minmax(0, 17rem);
    gap: var(--space-xl);
    align-items: stretch;       /* permet au track ToC d'occuper toute la hauteur */
    justify-content: center;
  }

  .q__body {
    min-width: 0;
    align-self: start;          /* l'article reste en haut, ne s'étire pas */
  }

  .q__toc-side {
    position: relative;
    height: 100%;               /* prend toute la hauteur du track pour permettre le sticky */
  }

  .q__themes {
    max-width: var(--measure);
    margin: var(--space-xl) auto 0;
    padding-top: var(--space-l);
  }

  .q__themes-title {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin: 0 0 var(--space-s);
  }

  .q__themes-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .q__theme-chip {
    display: inline-block;
  }

  .q__theme-chip a {
    display: inline-block;
    padding: 0.3em 0.75em;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--ink-soft);
    background-color: var(--paper-dim);
    border: 1px solid var(--rule);
    border-radius: 2px;
    text-decoration: none;
    transition: color 150ms ease, border-color 150ms ease, background-color 150ms ease;
  }

  .q__theme-chip a:hover,
  .q__theme-chip a:focus-visible {
    color: var(--rubric);
    border-color: var(--rubric);
    background-color: var(--paper);
  }

  .q__aside-missing {
    color: var(--muted);
    font-style: italic;
  }

  .q__footer {
    max-width: var(--measure);
    margin: var(--space-2xl) auto 0;
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
    text-align: center;
  }

  .q__disclaimer {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--muted);
    max-width: 56ch;
    margin: 0 auto var(--space-m);
    line-height: var(--line-height-prose);
  }

  .q__back {
    margin-top: var(--space-m);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
  }

  /* Mobile : la colonne ToC disparaît de la grille mais l'aside reste dans
     le DOM avec ses enfants en position: fixed (FAB + overlay). Ne PAS
     mettre display: none, sinon tous les descendants sont cachés même ceux
     en position: fixed. */
  @media (max-width: 900px) {
    .q__layout {
      grid-template-columns: minmax(0, 1fr);
    }
    .q__toc-side {
      /* Hauteur et visibilité neutres ; le nav sticky est caché par sa
         propre règle @media, le FAB et l'overlay sont fixed. */
      height: 0;
      overflow: visible;
    }
  }
</style>
