---
import Base from './Base.astro';
import FourVoices from '../components/FourVoices.astro';
import { getDocumentBySlug } from '../data/loadDocuments.js';
import { getThemeBySlug } from '../data/loadThemes.js';

interface Voice {
  tagline: string;
  body: string;
  punchline?: string;
}

interface Props {
  title: string;
  question: string;
  slug: string;
  date?: string;
  summary?: string;
  tags?: string[];
  related_documents?: string[];
  related_themes?: string[];
  posture?: 'traditionnelle' | 'neutre' | 'pastorale';
  voices?: {
    conciliaire?: Voice;
    ecclesia_dei?: Voice;
    fsspx?: Voice;
    sedevacantiste?: Voice;
  };
}

const {
  title,
  question,
  date,
  summary,
  tags = [],
  related_documents = [],
  related_themes = [],
  posture = 'traditionnelle',
  voices,
} = Astro.props;

const postureLabel: Record<string, string> = {
  traditionnelle: 'Posture traditionnelle',
  neutre: 'Posture neutre',
  pastorale: 'Posture pastorale',
};

const documentLinks = related_documents.map((s) => {
  const doc = getDocumentBySlug(s);
  return {
    slug: s,
    label: doc?.titre_fr ?? doc?.incipit ?? null,
  };
});

const themeLinks = related_themes.map((s) => {
  const theme = getThemeBySlug(s);
  return {
    slug: s,
    label: theme?.label ?? null,
  };
});

// Format date in French if present
let dateDisplay: string | null = null;
if (date) {
  try {
    const d = new Date(date);
    if (!Number.isNaN(d.getTime())) {
      dateDisplay = d.toLocaleDateString('fr-FR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    } else {
      dateDisplay = date;
    }
  } catch {
    dateDisplay = date;
  }
}
---

<Base title={title} description={summary ?? question}>
  <main class="q" id="main" data-pagefind-body>
    <header class="q__header">
      <p class="q__eyebrow">Question</p>
      <h1 class="q__title">{title}</h1>
      <p class="q__question">{question}</p>
      {summary && <p class="q__summary">{summary}</p>}

      <div class="q__meta">
        {dateDisplay && (
          <time class="q__date" datetime={date}>{dateDisplay}</time>
        )}
        <span class={`q__posture q__posture--${posture}`}>
          {postureLabel[posture] ?? posture}
        </span>
        {tags.length > 0 && (
          <ul class="q__tags" role="list">
            {tags.map((tag) => <li class="q__tag">{tag}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="q__layout">
      <article class="prose q__body">
        <slot />
        {voices && <FourVoices voices={voices} />}
      </article>

      <aside class="q__aside" aria-label="Références">
        {documentLinks.length > 0 && (
          <section class="q__aside-section">
            <h2 class="q__aside-title">Documents cités</h2>
            <ul class="q__aside-list" role="list">
              {documentLinks.map((d) => (
                <li>
                  {d.label ? (
                    <a href={`/documents/${d.slug}/`}>{d.label}</a>
                  ) : (
                    <span class="q__aside-missing" title="Document introuvable">
                      {d.slug}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}

        {themeLinks.length > 0 && (
          <section class="q__aside-section">
            <h2 class="q__aside-title">Thèmes associés</h2>
            <ul class="q__aside-list" role="list">
              {themeLinks.map((t) => (
                <li>
                  {t.label ? (
                    <a href={`/themes/${t.slug}/`}>{t.label}</a>
                  ) : (
                    <span class="q__aside-missing" title="Thème introuvable">
                      {t.slug}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </div>

    <footer class="q__footer">
      <p class="q__disclaimer">
        Cette fiche est une compilation magistérielle selon la posture
        apologétique traditionnelle assumée. Elle ne se substitue pas à
        l'enseignement vivant de l'Église.
      </p>
      <p class="q__back">
        <a href="/questions/">Toutes les questions</a>
      </p>
    </footer>
  </main>
</Base>

<style>
  .q {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-m);
  }

  .q__header {
    max-width: var(--measure);
    margin: 0 auto var(--space-xl);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
  }

  .q__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: var(--space-s);
  }

  .q__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-m);
  }

  .q__question {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 1.5vw + 0.75rem, 1.75rem);
    line-height: 1.35;
    color: var(--ink-soft);
    margin-bottom: var(--space-m);
  }

  .q__summary {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: var(--line-height-prose);
    margin-bottom: var(--space-m);
  }

  .q__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs) var(--space-s);
    margin-top: var(--space-m);
    font-size: 0.875rem;
  }

  .q__date {
    color: var(--muted);
    font-variant-numeric: oldstyle-nums;
  }

  .q__posture {
    display: inline-block;
    padding: 0.15em 0.6em;
    border: 1px solid var(--rule);
    border-radius: 2px;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background-color: var(--paper-dim);
  }

  .q__posture--traditionnelle {
    border-color: color-mix(in srgb, var(--rubric) 35%, var(--rule));
    color: var(--rubric);
  }

  .q__posture--pastorale {
    border-color: color-mix(in srgb, var(--gold) 50%, var(--rule));
    color: var(--gold);
  }

  .q__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs) var(--space-2xs);
    padding: 0;
    margin: 0;
  }

  .q__tag {
    display: inline-block;
    padding: 0.1em 0.55em;
    font-size: 0.8rem;
    font-family: var(--font-serif);
    color: var(--muted);
    background-color: var(--paper-dim);
    border-radius: 2px;
  }

  .q__layout {
    display: grid;
    grid-template-columns: minmax(0, var(--measure)) minmax(0, 18rem);
    gap: var(--space-xl);
    align-items: start;
    justify-content: center;
  }

  .q__body {
    min-width: 0;
  }

  .q__aside {
    position: sticky;
    top: var(--space-l);
    font-size: 0.95rem;
    padding: var(--space-m);
    border-left: 1px solid var(--rule);
  }

  .q__aside-section + .q__aside-section {
    margin-top: var(--space-l);
  }

  .q__aside-title {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: var(--space-s);
    padding-bottom: var(--space-3xs);
    border-bottom: 1px solid var(--rule);
  }

  .q__aside-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .q__aside-list li + li {
    margin-top: var(--space-2xs);
  }

  .q__aside-missing {
    color: var(--muted);
    font-style: italic;
  }

  .q__footer {
    max-width: var(--measure);
    margin: var(--space-2xl) auto 0;
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
    text-align: center;
  }

  .q__disclaimer {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--muted);
    max-width: 56ch;
    margin: 0 auto var(--space-m);
    line-height: var(--line-height-prose);
  }

  .q__back {
    margin-top: var(--space-m);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
  }

  /* Mobile : sidebar sous le corps */
  @media (max-width: 900px) {
    .q__layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .q__aside {
      position: static;
      border-left: 0;
      border-top: 1px solid var(--rule);
      padding: var(--space-m) 0 0;
    }
  }
</style>
