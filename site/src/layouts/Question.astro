---
import type { MarkdownHeading } from 'astro';
import Base from './Base.astro';
import FourVoices from '../components/FourVoices.astro';
import Tampon from '../components/Tampon.astro';
import ToC from '../components/ToC.astro';
import CulDeLampe from '../components/CulDeLampe.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import DocumentsGrid from '../components/DocumentsGrid.astro';
import { getThemeBySlug } from '../data/loadThemes.js';
import { marked } from 'marked';

const renderInline = (s: string | undefined) =>
  s ? (marked.parseInline(s, { async: false }) as string) : '';

interface Voice {
  tagline: string;
  body: string;
  punchline?: string;
}

interface Props {
  title: string;
  question: string;
  slug: string;
  date?: string;
  summary?: string;
  tags?: string[];
  related_documents?: string[];
  related_themes?: string[];
  posture?: 'traditionnelle' | 'neutre' | 'pastorale';
  tampon?:
    | 'casus_gravissimus'
    | 'quaestio_disputata'
    | 'de_fide_definita'
    | 'traditio_constans'
    | 'disciplina'
    | 'ad_mentem_pii_x';
  voices?: {
    conciliaire?: Voice;
    ecclesia_dei?: Voice;
    fsspx?: Voice;
    sedevacantiste?: Voice;
  };
  image?: string;
  model?: string;
  headings?: MarkdownHeading[];
}

const {
  title,
  question,
  date,
  summary,
  tags = [],
  related_documents = [],
  related_themes = [],
  posture = 'traditionnelle',
  tampon,
  voices,
  image,
  model = 'Claude Opus 4.7',
  headings = [],
} = Astro.props;

const postureLabel: Record<string, string> = {
  traditionnelle: 'Posture traditionnelle',
  neutre: 'Posture neutre',
  pastorale: 'Posture pastorale',
};

const themeLinks = related_themes.map((s) => {
  const theme = getThemeBySlug(s);
  return {
    slug: s,
    label: theme?.label ?? null,
  };
});

// Format date in French if present
let dateDisplay: string | null = null;
if (date) {
  try {
    const d = new Date(date);
    if (!Number.isNaN(d.getTime())) {
      dateDisplay = d.toLocaleDateString('fr-FR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    } else {
      dateDisplay = date;
    }
  } catch {
    dateDisplay = date;
  }
}
---

<Base title={title} description={summary ?? question}>
  <ReadingProgress />

  <main class="q" id="main" data-pagefind-body>
    <header class="q__header">
      {tampon && (
        <div class="q__tampon">
          <Tampon variant={tampon} />
        </div>
      )}
      {image && (
        <div class="q__hero-image" aria-hidden="true">
          <img src={image} alt="" width="600" height="600" loading="eager" />
        </div>
      )}
      <p class="q__eyebrow">Question</p>
      <h1 class="q__title" data-pagefind-meta="title" data-pagefind-weight="10.0">{title}</h1>
      <p class="q__question" data-pagefind-weight="5.0">{question}</p>
      {summary && <p class="q__summary" data-pagefind-weight="3.0" set:html={renderInline(summary)} />}

      <div class="q__meta">
        {dateDisplay && (
          <time class="q__date" datetime={date}>{dateDisplay}</time>
        )}
        <span class={`q__posture q__posture--${posture}`}>
          {postureLabel[posture] ?? posture}
        </span>
        <span class="q__model" title={`Fiche rédigée par ${model}`}>
          <span class="q__model-eyebrow">Rédigée par</span>
          <span class="q__model-name">{model}</span>
        </span>
        {tags.length > 0 && (
          <ul class="q__tags" role="list">
            {tags.map((tag) => <li class="q__tag">{tag}</li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="q__layout">
      <article class="prose q__body">
        <slot />
        <CulDeLampe />
        {voices && <FourVoices voices={voices} />}
      </article>

      <aside class="q__toc-side" aria-label="Sommaire">
        <ToC headings={headings} />
      </aside>
    </div>

    <DocumentsGrid slugs={related_documents} />

    {themeLinks.length > 0 && (
      <section class="q__themes" aria-labelledby="themes-assoc-title">
        <h2 id="themes-assoc-title" class="q__themes-title">Thèmes associés</h2>
        <ul class="q__themes-list" role="list">
          {themeLinks.map((t) => (
            <li class="q__theme-chip">
              {t.label ? (
                <a href={`/themes/${t.slug}/`}>{t.label}</a>
              ) : (
                <span class="q__aside-missing">{t.slug}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="q__footer">
      <p class="q__disclaimer">
        Cette fiche est une compilation magistérielle selon la posture
        apologétique traditionnelle assumée. Elle ne se substitue pas à
        l'enseignement vivant de l'Église.
      </p>
      <p class="q__back">
        <a href="/questions/">Toutes les questions</a>
      </p>
    </footer>
  </main>

  <BackToTop />
</Base>

<style>
  .q {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-m);
  }

  .q__header {
    position: relative;
    max-width: var(--measure);
    margin: 0 auto var(--space-xl);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
  }

  .q__tampon {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    z-index: 3;
    pointer-events: none;
  }

  /* Au hover du header (lecture du titre / question), le tampon se retire :
     fade rapide. À la sortie de hover, retour avec un easing bouncy → effet
     "slam de tampon". Les variables se cascadent dans <Tampon>. */
  .q__header:hover .q__tampon {
    --tampon-opacity: 0;
    --tampon-scale: 1.25;
    --tampon-duration: 160ms;
    --tampon-easing: ease-out;
  }

  /* Sur mobile, on ramène le tampon dans le flux pour ne pas qu'il déborde
     ou n'écrase le titre quand l'espace est étroit. */
  @media (max-width: 640px) {
    .q__tampon {
      position: static;
      display: flex;
      justify-content: flex-end;
      margin-bottom: var(--space-xs);
    }
  }

  .q__hero-image {
    display: flex;
    justify-content: center;
    margin: 0 auto var(--space-l);
    user-select: none;
  }

  .q__hero-image img {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
  }

  @media (max-width: 640px) {
    .q__hero-image img { max-width: 240px; }
  }

  .q__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: var(--space-s);
  }

  .q__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-m);
  }

  .q__question {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 1.5vw + 0.75rem, 1.75rem);
    line-height: 1.35;
    color: var(--ink-soft);
    margin-bottom: var(--space-m);
  }

  .q__summary {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: 1.75;
    margin: var(--space-m) 0;
    padding: var(--space-m) var(--space-l);
    border-left: 3px solid color-mix(in srgb, var(--rubric) 35%, var(--rule));
    background-color: var(--paper-dim);
    border-radius: 0 4px 4px 0;
    position: relative;
  }

  .q__summary::before {
    content: "Synthèse";
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.7rem;
    color: var(--muted);
    margin-bottom: var(--space-xs);
  }

  .q__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs) var(--space-s);
    margin-top: var(--space-m);
    font-size: 0.875rem;
  }

  .q__date {
    color: var(--muted);
    font-variant-numeric: oldstyle-nums;
  }

  .q__posture {
    display: inline-block;
    padding: 0.15em 0.6em;
    border: 1px solid var(--rule);
    border-radius: 2px;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background-color: var(--paper-dim);
  }

  .q__posture--traditionnelle {
    border-color: color-mix(in srgb, var(--rubric) 35%, var(--rule));
    color: var(--rubric);
  }

  .q__posture--pastorale {
    border-color: color-mix(in srgb, var(--gold) 50%, var(--rule));
    color: var(--gold);
  }

  .q__model {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .q__model-eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .q__model-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-soft);
    padding: 0.1em 0.5em;
    background-color: var(--paper-dim);
    border: 1px solid var(--rule);
    border-radius: 2px;
  }

  .q__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs) var(--space-2xs);
    padding: 0;
    margin: 0;
  }

  .q__tag {
    display: inline-block;
    padding: 0.1em 0.55em;
    font-size: 0.8rem;
    font-family: var(--font-serif);
    color: var(--muted);
    background-color: var(--paper-dim);
    border-radius: 2px;
  }

  .q__layout {
    display: grid;
    grid-template-columns: minmax(0, var(--measure)) minmax(0, 17rem);
    gap: var(--space-xl);
    align-items: stretch;       /* permet au track ToC d'occuper toute la hauteur */
    justify-content: center;
  }

  .q__body {
    min-width: 0;
    align-self: start;          /* l'article reste en haut, ne s'étire pas */
  }

  .q__toc-side {
    position: relative;
    height: 100%;               /* prend toute la hauteur du track pour permettre le sticky */
  }

  .q__themes {
    max-width: var(--measure);
    margin: var(--space-xl) auto 0;
    padding-top: var(--space-l);
  }

  .q__themes-title {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin: 0 0 var(--space-s);
  }

  .q__themes-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .q__theme-chip {
    display: inline-block;
  }

  .q__theme-chip a {
    display: inline-block;
    padding: 0.3em 0.75em;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--ink-soft);
    background-color: var(--paper-dim);
    border: 1px solid var(--rule);
    border-radius: 2px;
    text-decoration: none;
    transition: color 150ms ease, border-color 150ms ease, background-color 150ms ease;
  }

  .q__theme-chip a:hover,
  .q__theme-chip a:focus-visible {
    color: var(--rubric);
    border-color: var(--rubric);
    background-color: var(--paper);
  }

  .q__aside-missing {
    color: var(--muted);
    font-style: italic;
  }

  .q__footer {
    max-width: var(--measure);
    margin: var(--space-2xl) auto 0;
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
    text-align: center;
  }

  .q__disclaimer {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--muted);
    max-width: 56ch;
    margin: 0 auto var(--space-m);
    line-height: var(--line-height-prose);
  }

  .q__back {
    margin-top: var(--space-m);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
  }

  /* Mobile : la colonne ToC disparaît de la grille mais l'aside reste dans
     le DOM avec ses enfants en position: fixed (FAB + overlay). Ne PAS
     mettre display: none, sinon tous les descendants sont cachés même ceux
     en position: fixed. */
  @media (max-width: 900px) {
    .q__layout {
      grid-template-columns: minmax(0, 1fr);
    }
    .q__toc-side {
      /* Hauteur et visibilité neutres ; le nav sticky est caché par sa
         propre règle @media, le FAB et l'overlay sont fixed. */
      height: 0;
      overflow: visible;
    }
  }
</style>

<!-- Enluminures — bandeau gravé entre chaque section + cul-de-lampe en
     fin de fiche + lettrine sur le premier paragraphe de chaque section.
     Le contenu vient du markdown rendu dans le <slot /> et le bandeau est
     injecté en JS (DOM dynamique). On utilise is:global pour cibler tous
     ces nœuds. -->
<style is:global>
  /* Cul-de-lampe (composant final) + bandeau (injecté par le script) :
     mêmes propriétés de base, juste des largeurs différentes. */
  .q__body .cul-de-lampe,
  .q__body .bandeau {
    display: block;
    margin-left: auto;
    margin-right: auto;
    height: auto;
    user-select: none;
    opacity: 0.88;
    transition: opacity 200ms ease;
  }
  .q__body .cul-de-lampe:hover,
  .q__body .bandeau:hover {
    opacity: 1;
  }

  .q__body .cul-de-lampe {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-l);
    width: min(100%, 230px);
  }
  .q__body .bandeau {
    margin-top: var(--space-l);
    margin-bottom: 0;
    width: min(100%, 460px);
  }
  /* Le h2 qui suit un bandeau garde sa propre marge top, suffisante. */

  @media (max-width: 640px) {
    .q__body .cul-de-lampe {
      width: min(100%, 180px);
    }
    .q__body .bandeau {
      width: min(100%, 320px);
    }
  }

  /* Lettrine CSS — fallback pour les sections dont la première lettre
     n'a pas encore d'image gravée (lettrine image gérée par .lettrine
     ci-dessous, et le script JS retire la lettre du flux quand il
     l'a remplacée par l'image — donc :first-letter ne s'applique plus). */
  @media (min-width: 760px) {
    .q__body h2 + p:not(.has-lettrine)::first-letter {
      font-family: var(--font-display);
      float: left;
      font-size: 4.6em;
      line-height: 0.82;
      font-weight: 600;
      color: var(--rubric);
      padding: 0.06em 0.08em 0 0;
      margin: 0.04em 0.04em -0.04em 0;
    }
  }

  /* Lettrine image — gravure XVIIᵉ s. avec rinceaux qui débordent.
     Boîte de réservation au ratio de l'image source (600/578) pour
     éviter toute déformation. L'image native est rendue à 100 % de la
     boîte puis scale visuellement pour déborder, ce qui garantit que
     les proportions sont strictement conservées.
     Masque radial : lettre 100 % opaque au centre, fade progressif
     vers les bords pour que les rinceaux qui passent sur le texte
     deviennent un filigrane discret. */
  .q__body .lettrine {
    float: left;
    width: 5.5em;
    aspect-ratio: 600 / 578;
    margin: 0.5em 0.6em -0.1em 0;
    /* Pas de shape-outside : le texte coule à droite du rectangle de
       réservation, transition propre quand le float se termine.
       Pas de margin-left négatif : la lettrine reste dans le cadre du
       texte (le décor ne dépasse pas dans la marge). */
    position: relative;
    overflow: visible;
    user-select: none;
  }

  .q__body .lettrine img {
    width: 100%;
    height: 100%;
    display: block;
    transform: scale(1.3);
    transform-origin: center;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      circle at center,
      black 0%,
      black 38%,
      rgba(0, 0, 0, 0.6) 60%,
      rgba(0, 0, 0, 0.18) 88%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: radial-gradient(
      circle at center,
      black 0%,
      black 38%,
      rgba(0, 0, 0, 0.6) 60%,
      rgba(0, 0, 0, 0.18) 88%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  @media (max-width: 640px) {
    .q__body .lettrine {
      width: 4em;
      margin: 0.4em 0.4em -0.1em 0;
    }
    .q__body .lettrine img {
      transform: scale(1.25);
    }
  }
</style>

<script>
  // Lettrines disponibles — étendue au fur et à mesure des générations.
  const availableLettrines = new Set(['A', 'C', 'D', 'F', 'L', 'R']);

  const body = document.querySelector('.q__body');
  if (body) {
    // 1. Bandeau gravé avant chaque <h2> sauf le premier.
    const h2s = body.querySelectorAll(':scope > h2');
    h2s.forEach((h2, i) => {
      if (i === 0) return;
      const img = document.createElement('img');
      img.src = '/ornements/bandeau.png';
      img.alt = '';
      img.setAttribute('role', 'presentation');
      img.className = 'bandeau';
      img.width = 1000;
      img.height = 131;
      img.loading = 'lazy';
      h2.parentNode!.insertBefore(img, h2);
    });

    // 2. Lettrine gravée — premier <p> qui suit chaque <h2>, si la
    //    première lettre est disponible en image.
    h2s.forEach((h2) => {
      let next: Element | null = h2.nextElementSibling;
      while (next && next.tagName !== 'P') {
        if (next.tagName === 'H2' || next.tagName === 'H3') {
          next = null;
          break;
        }
        next = next.nextElementSibling;
      }
      if (!next) return;
      const p = next as HTMLParagraphElement;
      const text = p.textContent ?? '';
      const firstChar = text.trim().charAt(0).toUpperCase();
      if (!availableLettrines.has(firstChar)) return;

      // Trouver le premier nœud texte non-vide et y remplacer la première
      // lettre par un span.lettrine + image.
      const walker = document.createTreeWalker(p, NodeFilter.SHOW_TEXT);
      let firstTextNode: Text | null = null;
      while (walker.nextNode()) {
        const t = walker.currentNode as Text;
        if (t.textContent && t.textContent.trim().length > 0) {
          firstTextNode = t;
          break;
        }
      }
      if (!firstTextNode || !firstTextNode.textContent) return;

      const original = firstTextNode.textContent;
      const idx = original.search(/\S/);
      if (idx < 0) return;

      // Découpe : [whitespace prefix] + [lettre] + [reste].
      const prefix = original.slice(0, idx);
      const rest = original.slice(idx + 1);

      const lettrineSpan = document.createElement('span');
      lettrineSpan.className = 'lettrine';
      lettrineSpan.setAttribute('aria-hidden', 'true');
      const lettrineImg = document.createElement('img');
      lettrineImg.src = `/ornements/lettrines/${firstChar}.png`;
      lettrineImg.alt = '';
      lettrineImg.width = 600;
      lettrineImg.height = 600;
      lettrineImg.loading = 'lazy';
      lettrineSpan.appendChild(lettrineImg);

      // Conserver la lettre pour les lecteurs d'écran : on l'ajoute en
      // texte invisible visuellement mais lisible par AT.
      const srOnly = document.createElement('span');
      srOnly.className = 'sr-only';
      srOnly.textContent = firstChar;
      srOnly.style.cssText = 'position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;';

      // Reconstituer le paragraphe : prefix textuel + lettrine + sr-only + reste.
      const parent = firstTextNode.parentNode!;
      if (prefix) parent.insertBefore(document.createTextNode(prefix), firstTextNode);
      parent.insertBefore(lettrineSpan, firstTextNode);
      parent.insertBefore(srOnly, firstTextNode);
      firstTextNode.textContent = rest;

      // Marqueur pour désactiver le ::first-letter CSS sur ce paragraphe.
      p.classList.add('has-lettrine');
    });
  }
</script>
