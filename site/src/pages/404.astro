---
/**
 * Page 404 — erreur sobre avec lien retour à l'accueil.
 */
import Base from '../layouts/Base.astro';
---

<Base
  title="Page introuvable"
  description="La page demandée n'existe pas ou a été déplacée."
>
  <main id="main" class="error">
    <p class="error__code">404</p>
    <h1 class="error__title">Page introuvable</h1>
    <p class="error__text">
      La page demandée n'existe pas, a été déplacée, ou n'a pas encore été
      publiée. Le corpus documentaire est organisé en trois grands points
      d'entrée ; suivez l'un des liens ci-dessous.
    </p>
    <ul class="error__links" role="list">
      <li><a href="/">Retour à l'accueil</a></li>
      <li><a href="/documents/">Tous les documents</a></li>
      <li><a href="/themes/">Les thèmes doctrinaux</a></li>
      <li><a href="/questions/">Les fiches Q/R</a></li>
    </ul>
  </main>
</Base>

<style>
  .error {
    max-width: 60ch;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-m);
    text-align: center;
  }

  .error__code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw + 1rem, 7rem);
    font-weight: 600;
    color: var(--rubric);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: var(--space-s);
  }

  .error__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 1rem, 2.5rem);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: var(--space-m);
  }

  .error__text {
    font-family: var(--font-serif);
    color: var(--ink-soft);
    line-height: var(--line-height-prose);
    margin-bottom: var(--space-l);
  }

  .error__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  @media (min-width: 520px) {
    .error__links {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-m);
    }
  }
</style>
