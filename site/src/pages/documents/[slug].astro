---
/**
 * Route dynamique : une page HTML par document du corpus (1304 routes).
 * Le markdown brut est chargé depuis `magisterium/` via loadDocumentContent,
 * puis rendu en HTML via `marked`.
 */
import { marked } from 'marked';
import Document from '../../layouts/Document.astro';
import { loadAllDocuments, getDocumentBySlug } from '../../data/loadDocuments.ts';
import { loadDocumentContent } from '../../data/loadMarkdown.ts';

export async function getStaticPaths() {
  const docs = loadAllDocuments();
  // Une route par document ; les 1304 pages sont générées statiquement.
  return docs.map((doc) => ({ params: { slug: doc.slug } }));
}

const { slug } = Astro.params;
if (typeof slug !== 'string') {
  throw new Error('Paramètre de slug manquant');
}

const doc = getDocumentBySlug(slug);
if (doc === null) {
  throw new Error(`Document introuvable pour le slug : ${slug}`);
}

const loaded = loadDocumentContent(slug);
if (loaded === null) {
  throw new Error(`Contenu markdown introuvable pour le slug : ${slug}`);
}

// Configuration de marked : GFM activé, pas de highlight (désactive Shiki ici).
marked.setOptions({ gfm: true, breaks: false });
const renderedHtml: string = await marked.parse(loaded.content);
---

<Document
  doc={doc}
  meta={loaded.meta}
  lang={loaded.lang}
  renderedHtml={renderedHtml}
/>
