---
/**
 * Composant partagé rendant une tranche de documents + la pagination.
 * Utilisé par `/documents/` et `/documents/page/[page]/`.
 */
import Base from '../../layouts/Base.astro';
import type { Document } from '../../data/types.ts';

interface Props {
  pageDocs: Document[];
  currentPage: number;
  totalPages: number;
  totalCount: number;
}

const { pageDocs, currentPage, totalPages, totalCount } = Astro.props;

const PERIODE_LABELS: Readonly<Record<string, string>> = {
  'pre-vatican-ii': 'Pré-Vatican II',
  'vatican-ii': 'Vatican II',
  'post-vatican-ii': 'Post-Vatican II',
  fsspx: 'FSSPX',
};

function periodeBadgeClass(p: string): string {
  if (p === 'vatican-ii' || p === 'post-vatican-ii') return 'badge--rubric';
  if (p === 'pre-vatican-ii') return 'badge--gold';
  return 'badge--muted';
}

const FRENCH_MONTHS: readonly string[] = [
  'janv.', 'févr.', 'mars', 'avr.', 'mai', 'juin',
  'juill.', 'août', 'sept.', 'oct.', 'nov.', 'déc.',
];

function formatShortDate(iso: string | null): string {
  if (iso === null || iso.length === 0) return '—';
  const m = /^(\d{1,4})(?:-(\d{2}))?(?:-(\d{2}))?/.exec(iso);
  if (m === null) return iso;
  const year = Number.parseInt(m[1], 10);
  const monthIdx = m[2] !== undefined ? Number.parseInt(m[2], 10) - 1 : null;
  const day = m[3] !== undefined ? Number.parseInt(m[3], 10) : null;
  if (day !== null && monthIdx !== null && monthIdx >= 0 && monthIdx < 12) {
    return `${day} ${FRENCH_MONTHS[monthIdx]} ${year}`;
  }
  if (monthIdx !== null && monthIdx >= 0 && monthIdx < 12) {
    return `${FRENCH_MONTHS[monthIdx]} ${year}`;
  }
  return String(year);
}

function docTitle(doc: Document): string {
  return (doc.titre_fr ?? doc.incipit ?? doc.slug) as string;
}

function pageHref(n: number): string {
  return n === 1 ? '/documents/' : `/documents/page/${n}/`;
}
---

<Base
  title={currentPage === 1 ? 'Documents' : `Documents — page ${currentPage}`}
  description={`${totalCount} documents du magistère catholique, triés chronologiquement.`}
>
  <main class="idx" id="main">
    <header class="idx__header">
      <p class="idx__eyebrow">Corpus</p>
      <h1 class="idx__title">Documents</h1>
      <p class="idx__count">
        <strong>{totalCount}</strong> documents
        <span class="idx__pageinfo">— page {currentPage} / {totalPages}</span>
      </p>
    </header>

    <ol class="idx__list" role="list">
      {pageDocs.map((doc) => (
        <li class="idx__item">
          <a href={`/documents/${doc.slug}/`} class="idx__link">
            <div class="idx__main">
              <h2 class="idx__doc-title">{docTitle(doc)}</h2>
              <p class="idx__meta">
                {doc.auteur !== null && <span class="idx__author">{doc.auteur}</span>}
                {doc.auteur !== null && <span class="idx__sep">·</span>}
                <span class="idx__type">{doc.type}</span>
                <span class="idx__sep">·</span>
                <span class="idx__date">{formatShortDate(doc.date)}</span>
              </p>
            </div>
            <div class="idx__badges">
              <span class={`badge ${periodeBadgeClass(doc.periode)}`}>
                {PERIODE_LABELS[doc.periode] ?? doc.periode}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>

    {totalPages > 1 && (
      <nav class="idx__pager" aria-label="Pagination">
        {currentPage > 1 ? (
          <a href={pageHref(currentPage - 1)} rel="prev">← Précédent</a>
        ) : (
          <span class="idx__pager-disabled">← Précédent</span>
        )}
        <span class="idx__pager-center">Page {currentPage} / {totalPages}</span>
        {currentPage < totalPages ? (
          <a href={pageHref(currentPage + 1)} rel="next">Suivant →</a>
        ) : (
          <span class="idx__pager-disabled">Suivant →</span>
        )}
      </nav>
    )}
  </main>
</Base>

<style>
  .idx {
    max-width: 920px;
    margin: 0 auto;
    padding: var(--space-l) var(--space-m) var(--space-2xl);
  }

  .idx__header {
    text-align: center;
    padding-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-xl);
  }

  .idx__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: var(--space-2xs);
  }

  .idx__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 1rem, 3.25rem);
    margin-bottom: var(--space-s);
  }

  .idx__count {
    font-family: var(--font-serif);
    color: var(--ink-soft);
  }

  .idx__count strong {
    font-weight: 700;
    color: var(--ink);
  }

  .idx__pageinfo {
    color: var(--muted);
  }

  .idx__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .idx__item {
    border-bottom: 1px solid var(--rule);
  }

  .idx__item:first-child {
    border-top: 1px solid var(--rule);
  }

  .idx__link {
    display: flex;
    gap: var(--space-m);
    align-items: flex-start;
    justify-content: space-between;
    padding: var(--space-s) var(--space-2xs);
    text-decoration: none;
    color: inherit;
  }

  .idx__link:hover,
  .idx__link:focus-visible {
    background-color: var(--paper-dim);
  }

  .idx__main {
    min-width: 0;
    flex: 1;
  }

  .idx__doc-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: var(--space-3xs);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .idx__link:hover .idx__doc-title,
  .idx__link:focus-visible .idx__doc-title {
    color: var(--rubric);
  }

  .idx__meta {
    font-size: 0.88rem;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3em;
    align-items: baseline;
  }

  .idx__sep {
    color: var(--rule);
  }

  .idx__author {
    color: var(--ink-soft);
  }

  .idx__badges {
    flex-shrink: 0;
    display: flex;
    gap: var(--space-2xs);
    align-items: center;
    padding-top: 0.15em;
  }

  .badge {
    display: inline-block;
    padding: 0.18em 0.6em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid transparent;
    line-height: 1.4;
    white-space: nowrap;
  }

  .badge--rubric {
    color: var(--paper);
    background-color: var(--rubric);
  }

  .badge--gold {
    color: var(--ink);
    background-color: color-mix(in srgb, var(--gold) 28%, transparent);
    border-color: color-mix(in srgb, var(--gold) 55%, transparent);
  }

  .badge--muted {
    color: var(--ink-soft);
    background-color: var(--paper-dim);
    border-color: var(--rule);
  }

  .idx__pager {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-m);
    border-top: 1px solid var(--rule);
    font-family: var(--font-display);
    font-size: 0.95rem;
    gap: var(--space-s);
  }

  .idx__pager-center {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .idx__pager-disabled {
    color: var(--rule);
  }

  @media (max-width: 640px) {
    .idx__link {
      flex-direction: column;
      gap: var(--space-xs);
      padding: var(--space-s) 0;
    }

    .idx__badges {
      padding-top: 0;
    }

    .idx__doc-title {
      font-size: 1.05rem;
    }
  }
</style>
