---
/**
 * Homepage MagisterIA — hero épuré.
 * Frontispice gravé (gravure XVIIᵉ s.) + verset d'accroche + texte de
 * positionnement + un seul CTA. Pas de listing thèmes/questions/docs :
 * la navigation se fait via le header.
 */
import Base from '../layouts/Base.astro';
---

<Base
  title="MagisterIA"
  description="Le magistère catholique, lu et mis en perspective par l'intelligence artificielle, au service de la Tradition."
>
  <main id="main" class="home">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <div class="hero__text">
          <p class="hero__verse">
            <span
              class="hero__verse-latin"
              tabindex="0"
              data-trad="La vérité du Seigneur demeure éternellement."
              aria-label="Veritas Domini manet in æternum — La vérité du Seigneur demeure éternellement"
            >Veritas Domini manet in æternum.</span>
            <cite class="hero__verse-ref">Ps 116, 2</cite>
          </p>

          <h1 id="hero-title" class="hero__title">
            Le magistère catholique,<br />à la lumière de l'IA.
          </h1>

          <p class="hero__lede">
            Le corpus complet du magistère ecclésial — conciles, papes,
            dicastères, catéchismes, droit, liturgie — lu et mis en
            perspective par l'intelligence artificielle, au service de
            la Tradition.
          </p>

          <p class="hero__cta">
            <a class="hero__btn" href="/questions/">
              Parcourir les questions
              <span class="hero__btn-arrow" aria-hidden="true">→</span>
            </a>
          </p>
        </div>

        <div class="hero__image" aria-hidden="true">
          <img
            src="/hero-frontispice.png"
            alt=""
            width="800"
            height="1200"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .home {
    min-height: calc(100vh - 200px);
  }

  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-m);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.05fr 1fr;
      gap: var(--space-2xl);
      padding: var(--space-xl) 0;
    }
  }

  /* Texte hero */
  .hero__text {
    max-width: 38rem;
  }

  /* Verset latin avec tooltip */
  .hero__verse {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0 0 var(--space-l);
    line-height: 1.5;
  }

  .hero__verse-latin {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted color-mix(in srgb, var(--rubric) 50%, transparent);
    transition: color 150ms ease, border-color 150ms ease;
    outline-offset: 4px;
  }

  .hero__verse-latin:hover,
  .hero__verse-latin:focus-visible {
    color: var(--rubric);
    border-bottom-color: var(--rubric);
  }

  /* Tooltip CSS pur — apparait au hover/focus */
  .hero__verse-latin::after {
    content: attr(data-trad);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.6rem);
    transform: translateX(-50%) translateY(4px);
    background-color: var(--ink);
    color: var(--paper);
    font-family: var(--font-serif);
    font-style: normal;
    font-size: 0.875rem;
    line-height: 1.4;
    padding: 0.55rem 0.85rem;
    border-radius: 3px;
    white-space: nowrap;
    box-shadow: 0 6px 18px -8px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 180ms ease, transform 180ms ease, visibility 0s linear 180ms;
    z-index: 5;
  }

  .hero__verse-latin::before {
    /* Petite flèche en bas du tooltip */
    content: "";
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.2rem);
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border: 5px solid transparent;
    border-top-color: var(--ink);
    opacity: 0;
    visibility: hidden;
    transition: opacity 180ms ease, visibility 0s linear 180ms;
    z-index: 5;
  }

  .hero__verse-latin:hover::after,
  .hero__verse-latin:focus-visible::after,
  .hero__verse-latin:hover::before,
  .hero__verse-latin:focus-visible::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition-delay: 0s;
  }

  .hero__verse-ref {
    font-style: normal;
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin-left: 0.4em;
  }

  /* Titre principal */
  .hero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.25rem, 4.5vw + 0.5rem, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 var(--space-l);
  }

  /* Lede */
  .hero__lede {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 0 var(--space-xl);
    max-width: 36rem;
  }

  /* CTA */
  .hero__cta {
    margin: 0;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    padding: 0.85em 1.6em;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--paper);
    background-color: var(--rubric);
    text-decoration: none;
    border: 1px solid var(--rubric);
    transition: background-color 150ms ease, color 150ms ease, transform 200ms ease;
  }

  .hero__btn:hover,
  .hero__btn:focus-visible {
    background-color: var(--paper);
    color: var(--rubric);
    transform: translateX(2px);
  }

  .hero__btn-arrow {
    transition: transform 200ms ease;
  }

  .hero__btn:hover .hero__btn-arrow,
  .hero__btn:focus-visible .hero__btn-arrow {
    transform: translateX(3px);
  }

  /* Image hero */
  .hero__image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image img {
    width: 100%;
    max-width: 460px;
    height: auto;
    display: block;
    user-select: none;
  }

  @media (min-width: 900px) {
    .hero__image img {
      max-width: 520px;
    }
  }

  /* Réorganisation mobile : image au-dessus, texte en-dessous */
  @media (max-width: 899px) {
    .hero__inner {
      gap: var(--space-l);
    }
    .hero__image {
      order: -1;
    }
    .hero__image img {
      max-width: 320px;
    }
    .hero__text {
      text-align: center;
      margin: 0 auto;
    }
    .hero__lede {
      margin-left: auto;
      margin-right: auto;
    }
    .hero__verse-latin::after {
      white-space: normal;
      max-width: 80vw;
      width: max-content;
    }
  }
</style>
