---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import Question from '../../layouts/Question.astro';

export async function getStaticPaths() {
  const entries = await getCollection('questions');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'questions'>;
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const data = entry.data;

// Injecter les headings virtuels rendus par le layout (FourVoices) pour qu'ils
// apparaissent dans la ToC. Le <h2 id="voices-title"> est effectivement présent
// dans le DOM (rendu par FourVoices.astro), donc le scroll-spy fonctionne déjà.
const augmentedHeadings: MarkdownHeading[] = [
  ...headings,
  ...(data.voices
    ? [
        {
          depth: 2,
          slug: 'voices-title',
          text: 'Panorama — Les quatre voix',
        },
      ]
    : []),
];
---

<Question
  title={data.title}
  question={data.question}
  slug={entry.slug}
  date={data.date}
  summary={data.summary}
  tags={data.tags}
  related_documents={data.related_documents}
  related_themes={data.related_themes}
  posture={data.posture}
  tampon={data.tampon}
  voices={data.voices}
  image={data.image}
  model={data.model}
  headings={augmentedHeadings}
>
  <Content />
</Question>
