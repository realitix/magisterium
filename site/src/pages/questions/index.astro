---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Tampon from '../../components/Tampon.astro';

const entries = await getCollection('questions');

// Tri par date décroissante ; les entrées sans date passent à la fin.
const sorted = entries.slice().sort((a, b) => {
  const da = a.data.date ?? '';
  const db = b.data.date ?? '';
  if (!da && !db) return 0;
  if (!da) return 1;
  if (!db) return -1;
  return db.localeCompare(da);
});
---

<Base
  title="Questions doctrinales"
  description="Fiches de questions-réponses sur les tensions doctrinales du magistère contemporain."
>
  <main id="main" class="ql">
    <header class="ql__header">
      <p class="ql__eyebrow">MagisterIA</p>
      <h1 class="ql__title">Questions doctrinales</h1>
      <p class="ql__subtitle">
        Fiches de synthèse sur les tensions doctrinales, rédigées selon
        la posture apologétique traditionnelle.
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="ql__empty">Aucune fiche disponible pour l'instant.</p>
    ) : (
      <ul class="ql__grid" role="list">
        {sorted.map((entry) => {
          const d = entry.data;
          const slug = entry.slug;
          return (
            <li class="ql__item">
              <a
                class="qcard"
                href={`/questions/${slug}/`}
                aria-label={`Lire la fiche : ${d.title}`}
              >
                {d.tampon && (
                  <span class="qcard__tampon" aria-hidden="true">
                    <Tampon variant={d.tampon} />
                  </span>
                )}

                {d.image ? (
                  <span class="qcard__image" aria-hidden="true">
                    <img src={d.image} alt="" width="600" height="600" loading="lazy" />
                  </span>
                ) : (
                  <span class="qcard__image qcard__image--empty" aria-hidden="true"></span>
                )}

                <span class="qcard__question">{d.question}</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </main>
</Base>

<style>
  .ql {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-m) var(--space-2xl);
  }

  .ql__header {
    text-align: center;
    padding-bottom: var(--space-l);
    margin-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--rule);
  }

  .ql__eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: var(--space-s);
  }

  .ql__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw + 1rem, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-s);
  }

  .ql__subtitle {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink-soft);
    max-width: 52ch;
    margin: 0 auto;
    line-height: var(--line-height-prose);
  }

  .ql__empty {
    text-align: center;
    font-style: italic;
    color: var(--muted);
    padding: var(--space-xl) 0;
  }

  /* Grille de cartes — 1 / 2 / 2 colonnes selon la largeur. */
  .ql__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl) var(--space-xl);
    justify-items: center;
  }

  @media (min-width: 720px) {
    .ql__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .ql__item {
    margin: 0;
    width: 100%;
    max-width: 30rem;
  }

  /* Carte : entièrement cliquable, présentation type « page de livre ». */
  .qcard {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-m);
    padding: var(--space-l) var(--space-m);
    text-decoration: none;
    color: inherit;
    transition: transform 220ms ease, filter 220ms ease;
    isolation: isolate;
  }

  .qcard::before {
    /* Liseré décoratif — apparait au hover. */
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    transition: border-color 220ms ease, background-color 220ms ease;
    pointer-events: none;
    z-index: -1;
  }

  .qcard:hover,
  .qcard:focus-visible {
    transform: translateY(-3px);
  }

  .qcard:hover::before,
  .qcard:focus-visible::before {
    border-color: color-mix(in srgb, var(--rubric) 35%, var(--rule));
    background-color: color-mix(in srgb, var(--paper-dim) 70%, var(--paper));
  }

  .qcard:focus-visible {
    outline: 2px solid var(--rubric);
    outline-offset: 4px;
  }

  /* Image : grand médaillon centré, ratio 1:1. */
  .qcard__image {
    display: block;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
  }

  .qcard__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: opacity 220ms ease;
  }

  .qcard__image--empty {
    /* Placeholder : un simple petit fleuron centré pour les fiches sans image. */
    background-image: radial-gradient(
      circle,
      color-mix(in srgb, var(--muted) 18%, transparent) 1px,
      transparent 1px
    );
    background-size: 12px 12px;
    background-position: center;
    opacity: 0.4;
  }

  /* Question : l'élément textuel principal de la carte. */
  .qcard__question {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.05rem, 1vw + 0.9rem, 1.25rem);
    line-height: 1.4;
    color: var(--ink);
    text-align: center;
    max-width: 30ch;
  }

  .qcard:hover .qcard__question,
  .qcard:focus-visible .qcard__question {
    color: var(--rubric);
  }

  /* Tampon — position absolue, fade au hover de la carte
     (effet « slam » lors du retour, comme dans Question.astro). */
  .qcard__tampon {
    position: absolute;
    top: var(--space-s);
    right: var(--space-s);
    z-index: 3;
    pointer-events: none;
  }

  .qcard:hover .qcard__tampon,
  .qcard:focus-visible .qcard__tampon {
    --tampon-opacity: 0;
    --tampon-scale: 1.25;
    --tampon-duration: 160ms;
    --tampon-easing: ease-out;
  }

  @media (max-width: 520px) {
    .qcard__tampon {
      top: var(--space-xs);
      right: var(--space-xs);
      transform: scale(0.85);
      transform-origin: top right;
    }
    .qcard__image {
      max-width: 240px;
    }
  }
</style>
